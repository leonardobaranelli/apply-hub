# PostgreSQL (local container)
POSTGRES_USER=applyhub
POSTGRES_PASSWORD=applyhub_dev
POSTGRES_DB=applyhub
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=3001
NODE_ENV=development
# Primary connection consumed by Prisma. Use service name "postgres" inside Docker.
DATABASE_URL=postgresql://applyhub:applyhub_dev@postgres:5432/applyhub?schema=public
# Optional replica/backup database. When set, every successful write on the
# primary is replicated asynchronously. Use the EXTERNAL URL (with sslmode=require)
# if your replica lives on any managed provider.
# DATABASE_URL_REPLICA=postgresql://user:pass@replica-host:5432/db?sslmode=require
DATABASE_URL_REPLICA=
DATABASE_LOGGING=false
CORS_ORIGIN=http://localhost:5173

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3001/api
