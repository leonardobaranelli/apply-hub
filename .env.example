# PostgreSQL
POSTGRES_USER=applyhub
POSTGRES_PASSWORD=applyhub_dev
POSTGRES_DB=applyhub
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=3001
NODE_ENV=development
# Connection string consumed by Prisma. Use service name "postgres" inside Docker.
DATABASE_URL=postgresql://applyhub:applyhub_dev@postgres:5432/applyhub?schema=public
DATABASE_LOGGING=false
CORS_ORIGIN=http://localhost:5173

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3001/api
