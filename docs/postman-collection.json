{
  "info": {
    "name": "ApplyHub API",
    "_postman_id": "5b9e4f00-1a2b-4c3d-9e10-applyhubapi01",
    "description": "Full API surface of the ApplyHub backend (NestJS, prefix `/api`).\n\nCollection variables:\n- `baseUrl` — defaults to `http://localhost:3001/api`.\n- `applicationId` — placeholder UUID used by application-scoped requests.\n- `searchSessionId`, `contactId`, `templateId`, `eventId` — placeholder UUIDs.\n\nReplace the variables with real values once you have created the resources.\n\nNo authentication is required — the API assumes a controlled network perimeter.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001/api" },
    { "key": "applicationId", "value": "00000000-0000-0000-0000-000000000000" },
    { "key": "searchSessionId", "value": "00000000-0000-0000-0000-000000000000" },
    { "key": "contactId", "value": "00000000-0000-0000-0000-000000000000" },
    { "key": "templateId", "value": "00000000-0000-0000-0000-000000000000" },
    { "key": "eventId", "value": "00000000-0000-0000-0000-000000000000" }
  ],
  "item": [
    {
      "name": "Applications",
      "item": [
        {
          "name": "Create application",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/applications", "host": ["{{baseUrl}}"], "path": ["applications"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"Acme\",\n  \"companyUrl\": \"https://acme.com\",\n  \"roleTitle\": \"Senior Backend\",\n  \"jobTitle\": \"Backend Engineer\",\n  \"position\": \"backend\",\n  \"jobDescription\": \"We are hiring a backend engineer…\",\n  \"jobUrl\": \"https://acme.com/jobs/123\",\n  \"location\": \"Remote · LATAM\",\n  \"workMode\": \"remote\",\n  \"employmentType\": \"full_time\",\n  \"applicationDate\": \"2026-05-06\",\n  \"vacancyPostedDate\": \"2026-05-04\",\n  \"applicationMethod\": \"linkedin_easy_apply\",\n  \"source\": \"LinkedIn\",\n  \"platform\": \"LinkedIn\",\n  \"salaryMin\": 120000,\n  \"salaryMax\": 150000,\n  \"currency\": \"USD\",\n  \"salaryPeriod\": \"year\",\n  \"priority\": \"medium\",\n  \"tags\": [\"nodejs\", \"remote\"],\n  \"notes\": \"Referred by Jane.\",\n  \"resumeVersion\": \"English version\",\n  \"postingLanguage\": \"en\",\n  \"contactName\": \"Ada Lovelace\",\n  \"contactLinkedin\": \"https://linkedin.com/in/ada\",\n  \"contactEmail\": \"ada@acme.com\"\n}"
            }
          }
        },
        {
          "name": "List applications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/applications?page=1&limit=25&sortBy=applicationDate&sortDir=desc",
              "host": ["{{baseUrl}}"],
              "path": ["applications"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "25" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "status", "value": "applied,screening", "disabled": true },
                { "key": "stage", "value": "", "disabled": true },
                { "key": "position", "value": "backend,fullstack", "disabled": true },
                { "key": "method", "value": "linkedin_easy_apply", "disabled": true },
                { "key": "workMode", "value": "remote", "disabled": true },
                { "key": "priority", "value": "high", "disabled": true },
                { "key": "companyName", "value": "Acme", "disabled": true },
                { "key": "tags", "value": "nodejs,remote", "disabled": true },
                { "key": "fromDate", "value": "2026-01-01", "disabled": true },
                { "key": "toDate", "value": "2026-12-31", "disabled": true },
                { "key": "onlyActive", "value": "true", "disabled": true },
                { "key": "includeArchived", "value": "true", "disabled": true },
                { "key": "sortBy", "value": "applicationDate" },
                { "key": "sortDir", "value": "desc" }
              ]
            }
          }
        },
        {
          "name": "Get application by id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/applications/{{applicationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["applications", "{{applicationId}}"]
            }
          }
        },
        {
          "name": "Update application (partial)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/applications/{{applicationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["applications", "{{applicationId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Updated notes\",\n  \"priority\": \"high\",\n  \"tags\": [\"nodejs\", \"remote\", \"interesting\"]\n}"
            }
          }
        },
        {
          "name": "Change status (transactional + emits event)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/applications/{{applicationId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["applications", "{{applicationId}}", "status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"screening\",\n  \"stage\": \"recruiter_screen\",\n  \"title\": \"Recruiter call scheduled\",\n  \"description\": \"30 min intro chat next Tuesday.\",\n  \"channel\": \"video_call\",\n  \"occurredAt\": \"2026-05-06T10:00:00Z\",\n  \"metadata\": { \"agency\": \"Acme HR\" }\n}"
            }
          }
        },
        {
          "name": "Replace linked contacts",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/applications/{{applicationId}}/contacts",
              "host": ["{{baseUrl}}"],
              "path": ["applications", "{{applicationId}}", "contacts"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contactIds\": [\"{{contactId}}\"]\n}"
            }
          }
        },
        {
          "name": "Archive application",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/applications/{{applicationId}}/archive",
              "host": ["{{baseUrl}}"],
              "path": ["applications", "{{applicationId}}", "archive"]
            }
          }
        },
        {
          "name": "Restore application",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/applications/{{applicationId}}/restore",
              "host": ["{{baseUrl}}"],
              "path": ["applications", "{{applicationId}}", "restore"]
            }
          }
        },
        {
          "name": "Mark stale as ghosted",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/applications/mark-stale-ghosted?days=21",
              "host": ["{{baseUrl}}"],
              "path": ["applications", "mark-stale-ghosted"],
              "query": [{ "key": "days", "value": "21" }]
            }
          }
        },
        {
          "name": "Delete application",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/applications/{{applicationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["applications", "{{applicationId}}"]
            }
          }
        }
      ]
    },
