{
  "name": "applyhub-backend",
  "version": "1.0.0",
  "description": "ApplyHub backend API - NestJS",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:db:push": "prisma db push",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "node scripts/prisma-studio-local.mjs",
    "seed": "ts-node -r tsconfig-paths/register src/database/seed.ts",
    "prisma:db:push:replica": "node scripts/run-on-replica.mjs npx prisma db push --skip-generate && prisma generate",
    "prisma:studio:replica": "node scripts/run-on-replica.mjs npx prisma studio",
    "seed:replica": "node scripts/run-on-replica.mjs npm run seed",
    "db:sync:local-to-replica": "node scripts/db-sync.mjs local-to-replica",
    "db:sync:replica-to-local": "node scripts/db-sync.mjs replica-to-local",
    "db:sync:incremental:local-to-replica": "node scripts/db-sync-incremental.mjs local-to-replica",
    "db:sync:incremental:replica-to-local": "node scripts/db-sync-incremental.mjs replica-to-local",
    "db:status": "node scripts/db-status.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "joi": "^17.13.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
